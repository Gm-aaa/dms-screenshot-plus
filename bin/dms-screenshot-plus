#!/usr/bin/env bash
# ==============================================================================
# dms-screenshot-plus
# ------------------------------------------------------------------------------
# A polished, menu-driven Wayland screenshot toolkit for tiling compositors
# (niri / Hyprland / Sway / wlroots). One launcher, four capture modes:
#
#   • Region      — freeze the screen, select an area, capture to RAM.
#   • Fullscreen  — capture the focused / chosen output (or every output).
#   • OCR         — select a region, extract text, copy it to the clipboard.
#   • Scrolling   — stitch a long screenshot via wayscrollshot.
#
# Captures land in tmpfs (never touch the disk) until you choose what to do
# with them from a single 6-action notification: copy path / copy image /
# save to disk / open folder / annotate / pin-on-top.
#
# Design goals: zero hardcoded paths (XDG + config file + env overrides),
# graceful dependency degradation, bilingual UI (zh / en), and a GUI menu
# rendered through fuzzel/wofi/rofi/bemenu (with an fzf/terminal fallback).
#
# Usage:   dms-screenshot-plus [menu|region|fullscreen|ocr|scroll]
# Help:    dms-screenshot-plus -h
#
# SPDX-License-Identifier: MIT
# ==============================================================================

set -Eeuo pipefail

APP_NAME="dms-screenshot-plus"
APP_VERSION="0.1.0"

# ------------------------------------------------------------------------------
# Diagnostics
# ------------------------------------------------------------------------------
# DSP_DEBUG=1 dms-screenshot-plus ...  -> full trace to $XDG_RUNTIME_DIR log
if [[ -n "${DSP_DEBUG:-}" ]]; then
    _dbg_log="${XDG_RUNTIME_DIR:-/tmp}/${APP_NAME}.log"
    exec 2>>"$_dbg_log"
    set -x
fi

die() { notify "${1:-error}"; printf '%s: %s\n' "$APP_NAME" "${1:-error}" >&2; exit 1; }
has() { command -v "$1" >/dev/null 2>&1; }

# clip [wl-copy-args...] — pipe stdin to the Wayland clipboard.
# Returns non-zero (without aborting) when no clipboard tool is installed, so
# callers can degrade gracefully instead of dying under `set -e` / pipefail.
# Only call it in a guarded context (if / || / after a has-wl-copy check).
clip() { has wl-copy || return 1; wl-copy "$@"; }

# ------------------------------------------------------------------------------
# Configuration
# ------------------------------------------------------------------------------
# Precedence (low -> high): built-in defaults < config file < environment.
# Config file: $XDG_CONFIG_HOME/dms-screenshot-plus/config  (sourced as shell).
# Every knob below is also an environment variable, so nothing is hardcoded.
# ------------------------------------------------------------------------------
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
CONFIG_DIR="$XDG_CONFIG_HOME/$APP_NAME"
CONFIG_FILE="$CONFIG_DIR/config"

# Resolve the user's Pictures directory without assuming a fixed name.
_default_pictures() {
    local p=""
    has xdg-user-dir && p="$(xdg-user-dir PICTURES 2>/dev/null || true)"
    [[ -n "$p" && "$p" != "$HOME" ]] || p="$HOME/Pictures"
    printf '%s' "$p"
}

# --- defaults (only set if not already provided by the environment) -----------
: "${DSP_SAVE_DIR:=$(_default_pictures)/Screenshots}"
: "${DSP_MEM_DIR:=$XDG_RUNTIME_DIR/$APP_NAME}"
: "${DSP_LANG:=auto}"                  # auto | zh | en
: "${DSP_MENU_BACKEND:=auto}"          # auto | fuzzel | wofi | rofi | bemenu | fzf | term
: "${DSP_FREEZE:=yes}"                 # freeze the screen while selecting (hyprpicker)
: "${DSP_PLAY_SOUND:=yes}"
: "${DSP_SHUTTER_SOUND:=/usr/share/sounds/freedesktop/stereo/camera-shutter.oga}"
: "${DSP_NOTIFY_TIMEOUT:=3000}"        # ms, for transient confirmations
: "${DSP_EDITOR_CMD:=satty}"           # annotation editor; receives --filename
: "${DSP_IMAGE_VIEWER:=imv}"           # used to pin a shot on top
: "${DSP_FILENAME_FMT:=%Y-%m-%d_%H-%M-%S}"  # date(1) format for filenames
# --- OCR ----------------------------------------------------------------------
: "${DSP_OCR_BACKEND:=auto}"           # auto | rapidocr | tesseract | custom
: "${DSP_OCR_PYTHON:=}"                # python interpreter that can import rapidocr
: "${DSP_OCR_TESS_LANGS:=chi_sim+eng}" # tesseract -l value
: "${DSP_OCR_CMD:=}"                   # custom: command, image path appended as last arg
# Optional custom RapidOCR ONNX models (override the pip-bundled PP-OCRv3 set).
: "${DSP_OCR_DET_MODEL:=}"             # text-detection model (.onnx)
: "${DSP_OCR_REC_MODEL:=}"             # text-recognition model (.onnx)
: "${DSP_OCR_CLS_MODEL:=}"             # angle-classification model (.onnx)
# --- Scrolling ----------------------------------------------------------------
: "${DSP_SCROLL_CMD:=wayscrollshot --no-border -w 400 -o}"  # output path appended last

# Load the user config last-ish so it can override defaults but env still wins
# for anything the user exported explicitly is handled by re-exporting below.
DSP_CONFIG_ERR=""
if [[ -f "$CONFIG_FILE" ]]; then
    # Validate syntax first so a stray typo can't abort startup, and source with
    # errexit disabled so a failing command inside the (shell-sourced) config
    # degrades to "ignore it" instead of killing the whole app. The user is told
    # once, later, when notify/i18n are available (see main()).
    if bash -n "$CONFIG_FILE" 2>/dev/null; then
        set +e
        # shellcheck disable=SC1090
        source "$CONFIG_FILE"
        set -e
    else
        DSP_CONFIG_ERR="$CONFIG_FILE"
    fi
fi

mkdir -p "$DSP_MEM_DIR"

# ------------------------------------------------------------------------------
# Internationalisation
# ------------------------------------------------------------------------------
_resolve_lang() {
    case "$DSP_LANG" in
        zh|en) printf '%s' "$DSP_LANG" ;;
        *) case "${LC_ALL:-${LC_MESSAGES:-${LANG:-}}}" in
               zh_*|zh) printf 'zh' ;;
               *)       printf 'en' ;;
           esac ;;
    esac
}
DSP_UI_LANG="$(_resolve_lang)"

# msg <key> [printf-args...]
msg() {
    local k="$1"; shift || true
    local zh en
    case "$k" in
        app_title)        zh="截图 Screenshot";        en="Screenshot" ;;
        menu_region)      zh="区域截图";               en="Region" ;;
        menu_fullscreen)  zh="全屏 / 显示器截图";       en="Fullscreen / Output" ;;
        menu_ocr)         zh="OCR 文字提取";           en="OCR text extraction" ;;
        menu_scroll)      zh="滚动截图";               en="Scrolling capture" ;;
        title_main)       zh="截图";                   en="Screenshot" ;;
        title_output)     zh="选择显示器";             en="Select output" ;;
        output_all)       zh="全部显示器";             en="All outputs" ;;
        act_copy_path)    zh="复制路径";               en="Copy path" ;;
        act_copy_image)   zh="复制图片";               en="Copy image" ;;
        act_save)         zh="写入磁盘";               en="Save to disk" ;;
        act_open_dir)     zh="打开目录";               en="Open folder" ;;
        act_edit)         zh="编辑";                   en="Annotate" ;;
        act_pin)          zh="钉住置顶";               en="Pin on top" ;;
        n_captured)       zh="截图已捕获（路径已复制）"; en="Captured (path copied)" ;;
        n_captured_body)  zh="选择下一步：";           en="Choose next action:" ;;
        n_copied_path)    zh="已复制路径";             en="Path copied" ;;
        n_copied_image)   zh="已复制图片";             en="Image copied" ;;
        n_copied_image_b) zh="可直接粘贴原图";         en="Paste the original image anywhere" ;;
        n_saved)          zh="已写入磁盘";             en="Saved to disk" ;;
        n_no_clip)        zh="剪贴板不可用，已直接保存"; en="Clipboard unavailable — saved to disk instead" ;;
        err_config)       zh="配置文件有误，已忽略";     en="Config file invalid — ignored" ;;
        n_canceled)       zh="已取消";                 en="Canceled" ;;
        n_failed)         zh="失败";                   en="Failed" ;;
        n_no_region)      zh="未选择区域";             en="No region selected" ;;
        ocr_title)        zh="OCR 文字提取";           en="OCR" ;;
        ocr_ok)           zh="提取成功，已复制到剪贴板"; en="Extracted, copied to clipboard" ;;
        ocr_empty)        zh="未识别到文字";           en="No text recognised" ;;
        ocr_error)        zh="OCR 引擎异常（DSP_DEBUG=1 查看日志）"; en="OCR engine error (run with DSP_DEBUG=1 for logs)" ;;
        ocr_no_backend)   zh="未找到 OCR 引擎";         en="No OCR backend found" ;;
        ocr_no_backend_b) zh="安装 rapidocr 或 tesseract，或设置 DSP_OCR_CMD";
                          en="Install rapidocr or tesseract, or set DSP_OCR_CMD" ;;
        scroll_canceled)  zh="滚动截图已取消或失败";    en="Scrolling capture canceled or failed" ;;
        err_dep)          zh="缺少依赖：%s";           en="Missing dependency: %s" ;;
        err_no_grim)      zh="grim 截图失败";          en="grim failed to capture" ;;
        err_no_menu)      zh="未找到菜单程序";          en="No menu program found" ;;
        err_no_menu_b)    zh="请安装 fuzzel / wofi / rofi / bemenu"; en="Install fuzzel / wofi / rofi / bemenu" ;;
        menu_settings)    zh="设置";                   en="Settings" ;;
        title_settings)   zh="设置";                   en="Settings" ;;
        set_language)     zh="语言";                   en="Language" ;;
        lang_auto)        zh="自动（跟随系统）";        en="Auto (follow system)" ;;
        lang_zh)          zh="中文";                   en="中文" ;;
        lang_en)          zh="English";                en="English" ;;
        set_back)         zh="返回";                   en="Back" ;;
        set_lang_changed) zh="语言已切换";             en="Language changed" ;;
        *)                zh="$k";                     en="$k" ;;
    esac
    local tmpl; [[ "$DSP_UI_LANG" == zh ]] && tmpl="$zh" || tmpl="$en"
    # shellcheck disable=SC2059
    printf "$tmpl" "$@"
}

# ------------------------------------------------------------------------------
# Notifications
# ------------------------------------------------------------------------------
notify() {
    has notify-send || return 0
    local timeout="$DSP_NOTIFY_TIMEOUT" icon=""
    [[ "${1:-}" == "-t" ]] && { timeout="$2"; shift 2; }
    [[ "${1:-}" == "-i" ]] && { icon="$2"; shift 2; }
    if [[ -n "$icon" ]]; then
        notify-send -a "$(msg app_title)" -t "$timeout" -i "$icon" "$1" "${2:-}"
    else
        notify-send -a "$(msg app_title)" -t "$timeout" "$1" "${2:-}"
    fi
}

# ------------------------------------------------------------------------------
# Menu backend (GUI dmenu-style picker with graceful fallbacks)
# ------------------------------------------------------------------------------
_pick_menu_backend() {
    local pref="${DSP_MENU_BACKEND,,}"
    case "$pref" in
        fuzzel|wofi|rofi|bemenu|fzf|term)
            if [[ "$pref" == term ]] || has "$pref"; then printf '%s' "$pref"; return; fi ;;
    esac
    # auto: prefer a real terminal picker when run interactively, else GUI.
    if [[ -t 0 ]] && [[ "$(tty 2>/dev/null || true)" == /dev/pts/* ]]; then
        has fzf && { printf 'fzf'; return; }
        printf 'term'; return
    fi
    local b
    for b in fuzzel wofi rofi bemenu; do has "$b" && { printf '%s' "$b"; return; }; done
    printf 'none'
}

# menu_pick <title> <item...>  -> prints chosen item, returns 130 on cancel
menu_pick() {
    local title="${1:-Select}"; shift
    local items=("$@")
    ((${#items[@]})) || return 130
    local backend sel rc=130
    backend="$(_pick_menu_backend)"
    case "$backend" in
        fuzzel) set +e; sel="$(printf '%s\n' "${items[@]}" | fuzzel --dmenu --auto-select -p "$title")"; rc=$?; set -e ;;
        wofi)   set +e; sel="$(printf '%s\n' "${items[@]}" | wofi --dmenu --prompt "$title")"; rc=$?; set -e ;;
        rofi)   set +e; sel="$(printf '%s\n' "${items[@]}" | rofi -dmenu -p "$title")"; rc=$?; set -e ;;
        bemenu) set +e; sel="$(printf '%s\n' "${items[@]}" | bemenu -p "$title")"; rc=$?; set -e ;;
        fzf)    set +e; sel="$(printf '%s\n' "${items[@]}" | fzf --prompt "$title > " --layout=reverse --height=40% --border)"; rc=$?; set -e ;;
        term)
            printf '%s\n' "$title" >&2
            local i=1 it
            for it in "${items[@]}"; do printf '  %d) %s\n' "$i" "$it" >&2; ((i++)); done
            printf '> ' >&2
            local idx; set +e; read -r idx; rc=$?; set -e
            if [[ $rc -eq 0 && "$idx" =~ ^[0-9]+$ ]] && (( idx>=1 && idx<=${#items[@]} )); then
                sel="${items[$((idx-1))]}"; rc=0
            else rc=130; fi ;;
        none) notify "$(msg err_no_menu)" "$(msg err_no_menu_b)"; return 130 ;;
    esac
    [[ $rc -ne 0 || -z "${sel:-}" ]] && return 130
    printf '%s' "${sel//$'\r'/}"
}

# ------------------------------------------------------------------------------
# Compositor abstraction: enumerate outputs (monitors)
# ------------------------------------------------------------------------------
list_outputs() {
    if   has niri    && has jq; then niri msg -j outputs 2>/dev/null | jq -r 'keys[]'
    elif has niri;             then niri msg outputs 2>/dev/null | awk -F'[()]' '/^Output/{print $2}'
    elif has hyprctl && has jq; then hyprctl monitors -j 2>/dev/null | jq -r '.[].name'
    elif has swaymsg && has jq; then swaymsg -t get_outputs 2>/dev/null | jq -r '.[].name'
    elif has wlr-randr;        then wlr-randr 2>/dev/null | awk '/^[^ ]/{print $1}'
    fi | awk 'NF>0{print $1}' | sort -u || true
}

# ------------------------------------------------------------------------------
# Capture primitives
# ------------------------------------------------------------------------------
# The freeze layer's PID is tracked through a file, not a shell variable:
# select_region() runs inside a command substitution (a subshell), so a
# variable set there never reaches the caller's freeze_stop. A file does.
_freeze_pidfile="$DSP_MEM_DIR/.freeze.pid"
freeze_start() {
    [[ "${DSP_FREEZE,,}" == yes ]] || return 0
    has hyprpicker || return 0
    # Detach stdout/stderr. Without this, hyprpicker inherits the parent
    # command-substitution pipe and holds it open, so $(select_region) cannot
    # return until hyprpicker exits — which only happens on an extra click.
    hyprpicker -r -z -q >/dev/null 2>&1 &
    printf '%s' "$!" > "$_freeze_pidfile"
    sleep 0.2   # let the frozen layer map before slurp draws on it
}
freeze_stop() {
    [[ -f "$_freeze_pidfile" ]] || return 0
    local pid; pid="$(cat "$_freeze_pidfile" 2>/dev/null || true)"
    [[ -n "$pid" ]] && kill "$pid" 2>/dev/null || true
    rm -f "$_freeze_pidfile"
}

# Single cleanup path for every exit route: tear down the frozen overlay (a
# leftover hyprpicker freezes the whole screen) and remove any temp OCR image.
# Uses a file-scope var — not a function local — so it is still in scope when
# the EXIT trap fires at the top level under `set -u`.
# (Command-substitution subshells reset traps, so $(select_region) will NOT
# fire this and unfreeze before grim gets to capture.)
_ocr_tmp=""
_cleanup() { freeze_stop; [[ -n "${_ocr_tmp:-}" ]] && rm -f "$_ocr_tmp" 2>/dev/null || true; }
trap _cleanup EXIT
trap 'exit 130' INT TERM

# select_region [slurp-args...] -> prints geometry, returns 1 on cancel/Esc
select_region() {
    has slurp || die "$(msg err_dep "slurp")"
    local geom
    freeze_start
    if geom="$(slurp "$@")"; then
        printf '%s' "$geom"; return 0
    fi
    freeze_stop
    return 1
}

play_shutter() {
    [[ "${DSP_PLAY_SOUND,,}" == yes ]] || return 0
    [[ -r "$DSP_SHUTTER_SOUND" ]] || return 0
    has pw-play && pw-play "$DSP_SHUTTER_SOUND" >/dev/null 2>&1 &
    return 0
}

new_tmp_png() {
    # Keep only the latest in-RAM shot; clear stragglers from the last run.
    rm -f "$DSP_MEM_DIR"/*.png 2>/dev/null || true
    printf '%s' "$DSP_MEM_DIR/$(date +"$DSP_FILENAME_FMT").png"
}

# ------------------------------------------------------------------------------
# Shared post-capture handler — one notification, six actions.
# Default action (no click / timeout): the path is already on the clipboard.
# post_capture_image <png>
# ------------------------------------------------------------------------------
post_capture_image() {
    local tmp="$1"
    [[ -s "$tmp" ]] || { notify "$(msg n_failed)" "$(msg err_no_grim)"; return 1; }

    play_shutter

    # No clipboard tool → the entire copy-centric action menu is meaningless.
    # Persist the shot straight to disk and tell the user where it landed.
    if ! has wl-copy; then
        local nc_dest="$DSP_SAVE_DIR/$(basename "$tmp")"
        if mkdir -p "$DSP_SAVE_DIR" 2>/dev/null && mv "$tmp" "$nc_dest"; then
            notify -t 4000 -i "$nc_dest" "$(msg n_saved)" "$nc_dest"$'\n'"$(msg n_no_clip)"
        else
            notify "$(msg n_failed)" "$tmp"
        fi
        return 0
    fi

    printf '%s' "$tmp" | clip   # path-first: clipboard is useful even if ignored

    local action
    action="$(notify-send -a "$(msg app_title)" \
        -i "$tmp" \
        -A "path=$(msg act_copy_path)" \
        -A "image=$(msg act_copy_image)" \
        -A "save=$(msg act_save)" \
        -A "dir=$(msg act_open_dir)" \
        -A "edit=$(msg act_edit)" \
        -A "pin=$(msg act_pin)" \
        "$(msg n_captured)" "$(msg n_captured_body)")" || action=""

    local base ts dest
    base="$(basename "$tmp")"; ts="${base%.png}"

    case "$action" in
        path)
            notify -t 2000 "$(msg n_copied_path)" "$tmp" ;;
        image)
            clip --type image/png < "$tmp"
            notify -t 2000 -i "$tmp" "$(msg n_copied_image)" "$(msg n_copied_image_b)" ;;
        save)
            dest="$DSP_SAVE_DIR/$base"
            if mkdir -p "$DSP_SAVE_DIR" 2>/dev/null && mv "$tmp" "$dest"; then
                printf '%s' "$dest" | clip
                notify -t 3000 -i "$dest" "$(msg n_saved)" "$dest"
            else
                notify "$(msg n_failed)" "$dest"
            fi ;;
        dir)
            # Reveal-and-select via the freedesktop FileManager1 D-Bus API,
            # falling back to just opening the containing folder.
            { gdbus call --session --dest org.freedesktop.FileManager1 \
                --object-path /org/freedesktop/FileManager1 \
                --method org.freedesktop.FileManager1.ShowItems \
                "['file://$tmp']" "" >/dev/null 2>&1 \
                || gio open "$(dirname "$tmp")" >/dev/null 2>&1; } & ;;
        edit)
            local ed="${DSP_EDITOR_CMD%% *}"
            if ! has "$ed"; then notify "$(msg n_failed)" "$(msg err_dep "$ed")"; return 1; fi
            mkdir -p "$DSP_SAVE_DIR"
            # shellcheck disable=SC2086
            $DSP_EDITOR_CMD --filename "$tmp" \
                --output-filename "$DSP_SAVE_DIR/$ts-edited.png" \
                --copy-command wl-copy >/dev/null 2>&1 & ;;
        pin)
            local vw="${DSP_IMAGE_VIEWER%% *}"
            if ! has "$vw"; then notify "$(msg n_failed)" "$(msg err_dep "$vw")"; return 1; fi
            # Copy out of the auto-cleared mem dir so the next shot won't delete it.
            local pindir="$DSP_MEM_DIR/pinned" pinimg
            mkdir -p "$pindir"
            pinimg="$pindir/pinned-shot-$ts.png"
            if ! cp "$tmp" "$pinimg"; then notify "$(msg n_failed)" "$tmp"; return 1; fi
            # shellcheck disable=SC2086
            $DSP_IMAGE_VIEWER "$pinimg" >/dev/null 2>&1 & ;;
        *) : ;;  # dismissed / timed out: path already on clipboard
    esac
}

# ------------------------------------------------------------------------------
# Modes
# ------------------------------------------------------------------------------
mode_region() {
    has grim || die "$(msg err_dep "grim")"
    local geom tmp
    geom="$(select_region)" || exit 0   # Esc -> silent cancel
    tmp="$(new_tmp_png)"
    grim -g "$geom" "$tmp" || { freeze_stop; notify "$(msg n_failed)" "$(msg err_no_grim)"; exit 1; }
    freeze_stop
    post_capture_image "$tmp"
}

mode_fullscreen() {
    has grim || die "$(msg err_dep "grim")"
    local -a outs; mapfile -t outs < <(list_outputs)
    local tmp; tmp="$(new_tmp_png)"
    if (( ${#outs[@]} > 1 )); then
        local pick; pick="$(menu_pick "$(msg title_output)" "$(msg output_all)" "${outs[@]}")" || exit 0
        if [[ "$pick" == "$(msg output_all)" ]]; then grim "$tmp"
        else grim -o "$pick" "$tmp"; fi
    elif (( ${#outs[@]} == 1 )); then
        grim -o "${outs[0]}" "$tmp"
    else
        grim "$tmp"
    fi
    post_capture_image "$tmp"
}

mode_scroll() {
    has wayscrollshot || die "$(msg err_dep "wayscrollshot")"
    local tmp; tmp="$(new_tmp_png)"
    # DSP_SCROLL_CMD is a command whose final argument is the output path.
    # shellcheck disable=SC2086
    if ! $DSP_SCROLL_CMD "$tmp"; then
        notify -t 2000 "$(msg scroll_canceled)"; exit 0
    fi
    [[ -s "$tmp" ]] || exit 0
    post_capture_image "$tmp"
}

# --- OCR ----------------------------------------------------------------------
ocr_python_path() {
    if [[ -n "$DSP_OCR_PYTHON" ]]; then
        [[ -x "$DSP_OCR_PYTHON" ]] && { printf '%s' "$DSP_OCR_PYTHON"; return 0; }
        return 1
    fi
    local cand="$HOME/.local/share/rapidocr-venv/bin/python"
    if [[ -x "$cand" ]] && "$cand" -c 'import rapidocr_onnxruntime' 2>/dev/null; then
        printf '%s' "$cand"; return 0
    fi
    if has python3 && python3 -c 'import rapidocr_onnxruntime' 2>/dev/null; then
        printf 'python3'; return 0
    fi
    return 1
}

detect_ocr_backend() {
    [[ -n "$DSP_OCR_CMD" ]] && { printf 'custom'; return; }
    case "${DSP_OCR_BACKEND,,}" in
        rapidocr)  printf 'rapidocr' ;;
        tesseract) printf 'tesseract' ;;
        custom)    printf 'custom' ;;
        *)  if ocr_python_path >/dev/null; then printf 'rapidocr'
            elif has tesseract;          then printf 'tesseract'
            else printf 'none'; fi ;;
    esac
}

run_ocr() {  # <image> -> text on stdout
    local img="$1" backend; backend="$(detect_ocr_backend)"
    case "$backend" in
        rapidocr)
            local py; py="$(ocr_python_path)" || return 1
            # Keep onnxruntime's C++ chatter quiet normally, but let real errors
            # reach the debug log when DSP_DEBUG is set (fd 2 is the log then).
            # An engine exception exits 3 so the caller can tell "it crashed"
            # apart from "it ran and found no text" — the two used to look
            # identical (silent) and were impossible to diagnose.
            local errto=/dev/null; [[ -n "${DSP_DEBUG:-}" ]] && errto=/dev/stderr
            # Export the optional model overrides so the interpreter can see them.
            DSP_OCR_DET_MODEL="$DSP_OCR_DET_MODEL" \
            DSP_OCR_REC_MODEL="$DSP_OCR_REC_MODEL" \
            DSP_OCR_CLS_MODEL="$DSP_OCR_CLS_MODEL" \
            "$py" - "$img" 2>"$errto" <<'PY'
import sys, os, logging
logging.disable(logging.CRITICAL)
try:
    from rapidocr_onnxruntime import RapidOCR
    kw = {"print_verbose": False}
    for env, key in (("DSP_OCR_DET_MODEL", "det_model_path"),
                     ("DSP_OCR_REC_MODEL", "rec_model_path"),
                     ("DSP_OCR_CLS_MODEL", "cls_model_path")):
        v = os.environ.get(env)
        if v:
            kw[key] = v
    res, _ = RapidOCR(**kw)(sys.argv[1])
    if res:
        print('\n'.join(line[1] for line in res))
    else:
        print("rapidocr: engine ran, no text detected", file=sys.stderr)
except Exception:
    import traceback
    traceback.print_exc()
    sys.exit(3)   # engine error — distinct from a clean empty result
PY
            ;;
        tesseract)
            tesseract "$img" stdout -l "$DSP_OCR_TESS_LANGS" 2>/dev/null ;;
        custom)
            # shellcheck disable=SC2086
            $DSP_OCR_CMD "$img" ;;
        none) return 1 ;;
    esac
}

mode_ocr() {
    has grim || die "$(msg err_dep "grim")"
    if [[ "$(detect_ocr_backend)" == none ]]; then
        notify "$(msg ocr_no_backend)" "$(msg ocr_no_backend_b)"; exit 1
    fi
    local geom img
    geom="$(select_region)" || { notify -t 2000 "$(msg n_canceled)" "$(msg n_no_region)"; exit 0; }
    img="$(mktemp "${TMPDIR:-/tmp}/dsp-ocr-XXXXXX.png")"
    _ocr_tmp="$img"   # tracked by the global _cleanup EXIT trap
    grim -g "$geom" "$img" || { freeze_stop; notify "$(msg n_failed)" "$(msg err_no_grim)"; exit 1; }
    freeze_stop

    # Capture raw output and exit code separately so an engine crash (rc≠0) is
    # distinguishable from a clean "no text" result. The pipeline that trims
    # whitespace would otherwise mask run_ocr's exit code.
    local raw rc=0
    raw="$(run_ocr "$img")" || rc=$?
    local text
    text="$(printf '%s' "$raw" | sed 's/[[:space:]]*$//' | sed -e '/./,$!d' -e :a -e '/^\n*$/{$d;N;ba}')"
    if (( rc != 0 )); then
        notify "$(msg ocr_title)" "$(msg ocr_error)"
    elif [[ -n "$text" ]]; then
        if printf '%s' "$text" | clip; then
            notify "$(msg ocr_ok)" "$text"
        else
            notify "$(msg ocr_title)" "$text"   # no clipboard: at least show it
        fi
    else
        notify "$(msg ocr_title)" "$(msg ocr_empty)"
    fi
}

# ------------------------------------------------------------------------------
# Settings — persisted through the (shell-sourced) config file.
# ------------------------------------------------------------------------------
# config_set KEY VALUE — upsert `KEY="VALUE"` into $CONFIG_FILE atomically.
# An existing *uncommented* assignment is replaced in place; otherwise the line
# is appended. Commented example lines (e.g. copied from config.example) are
# left untouched — they are ignored on source, and the appended/edited active
# line wins.
config_set() {
    local key="$1" val="$2"
    mkdir -p "$CONFIG_DIR"
    local tmp; tmp="$(mktemp "$CONFIG_DIR/.config.XXXXXX")"
    local line="$key=\"$val\""
    if [[ -f "$CONFIG_FILE" ]] && grep -qE "^[[:space:]]*$key=" "$CONFIG_FILE"; then
        # Replace the first uncommented assignment; keep everything else verbatim.
        awk -v k="$key" -v repl="$line" '
            !done && $0 ~ ("^[[:space:]]*" k "=") { print repl; done=1; next }
            { print }
        ' "$CONFIG_FILE" > "$tmp"
    else
        [[ -f "$CONFIG_FILE" ]] && cat "$CONFIG_FILE" > "$tmp"
        printf '%s\n' "$line" >> "$tmp"
    fi
    mv "$tmp" "$CONFIG_FILE"
}

# settings_language — pick auto|zh|en, persist it, apply it live.
settings_language() {
    local cur="$DSP_LANG" mark_a="" mark_z="" mark_e=""
    case "$cur" in
        zh) mark_z="● " ;;
        en) mark_e="● " ;;
        *)  mark_a="● " ;;   # anything that isn't zh/en resolves as auto
    esac
    local A="${mark_a}$(msg lang_auto)" Z="${mark_z}$(msg lang_zh)" E="${mark_e}$(msg lang_en)"
    local pick; pick="$(menu_pick "$(msg set_language)" "$A" "$Z" "$E")" || return 0
    local val
    case "$pick" in
        "$A") val="auto" ;;
        "$Z") val="zh" ;;
        "$E") val="en" ;;
        *)    return 0 ;;
    esac
    config_set DSP_LANG "$val"
    DSP_LANG="$val"
    DSP_UI_LANG="$(_resolve_lang)"
    notify -t 2000 "$(msg set_lang_changed)"
}

# mode_settings — settings submenu; loops until Back/cancel.
mode_settings() {
    while true; do
        local L_LANG L_BACK pick cur_key
        # DSP_LANG may be auto|zh|en; anything else is treated as auto.
        case "$DSP_LANG" in zh) cur_key=lang_zh ;; en) cur_key=lang_en ;; *) cur_key=lang_auto ;; esac
        L_LANG="1 $(msg set_language): $(msg "$cur_key")"
        L_BACK="0 $(msg set_back)"
        pick="$(menu_pick "$(msg title_settings)" "$L_LANG" "$L_BACK")" || return 0
        case "$pick" in
            "$L_LANG") settings_language ;;
            "$L_BACK") return 0 ;;
            *)         return 0 ;;
        esac
    done
}

# ------------------------------------------------------------------------------
# Top-level menu
# ------------------------------------------------------------------------------
show_menu() {
    # Loop so the picker returns after a settings change, re-rendered in the
    # (possibly new) language. Capture actions run their mode and exit.
    while true; do
        local L_REGION L_FULL L_OCR L_SCROLL L_SETTINGS pick
        # Numbered prefixes let a single digit keystroke narrow fuzzel to one
        # match, which --auto-select then confirms immediately (no Enter needed).
        L_REGION="1 $(msg menu_region)"
        L_FULL="2 $(msg menu_fullscreen)"
        L_OCR="3 $(msg menu_ocr)"
        L_SCROLL="4 $(msg menu_scroll)"
        L_SETTINGS="5 $(msg menu_settings)"
        pick="$(menu_pick "$(msg title_main)" \
            "$L_REGION" "$L_FULL" "$L_OCR" "$L_SCROLL" "$L_SETTINGS")" || exit 0
        case "$pick" in
            "$L_REGION")   mode_region ;;
            "$L_FULL")     mode_fullscreen ;;
            "$L_OCR")      mode_ocr ;;
            "$L_SCROLL")   mode_scroll ;;
            "$L_SETTINGS") mode_settings; continue ;;  # back to menu, new lang
            *)             exit 0 ;;
        esac
        return
    done
}

# ------------------------------------------------------------------------------
# CLI
# ------------------------------------------------------------------------------
usage() {
    cat <<EOF
$APP_NAME $APP_VERSION — menu-driven Wayland screenshot toolkit

Usage:
  $APP_NAME [COMMAND]

Commands:
  menu                 Show the picker (default)
  region               Select a region and capture
  fullscreen | full    Capture an output (or all)
  ocr                  Select a region and OCR it to the clipboard
  scroll               Scrolling/long screenshot
  settings             Open the settings menu (switch UI language, …)

Options:
  -h, --help           Show this help
  -v, --version        Show version
      --print-config   Print the effective configuration

Configuration:
  Config file: $CONFIG_FILE  (sourced shell, optional)
  All DSP_* settings are overridable via environment variables.
  Run '$APP_NAME --print-config' to see current values.
EOF
}

print_config() {
    local v
    for v in DSP_SAVE_DIR DSP_MEM_DIR DSP_LANG DSP_MENU_BACKEND DSP_FREEZE \
             DSP_PLAY_SOUND DSP_SHUTTER_SOUND DSP_NOTIFY_TIMEOUT DSP_EDITOR_CMD \
             DSP_IMAGE_VIEWER DSP_FILENAME_FMT DSP_OCR_BACKEND DSP_OCR_PYTHON \
             DSP_OCR_TESS_LANGS DSP_OCR_CMD DSP_OCR_DET_MODEL DSP_OCR_REC_MODEL \
             DSP_OCR_CLS_MODEL DSP_SCROLL_CMD; do
        printf '%-22s = %s\n' "$v" "${!v}"
    done
    printf '%-22s = %s\n' "(resolved UI lang)" "$DSP_UI_LANG"
    printf '%-22s = %s\n' "(menu backend)" "$(_pick_menu_backend)"
    printf '%-22s = %s\n' "(OCR backend)" "$(detect_ocr_backend)"
}

main() {
    [[ -n "${DSP_CONFIG_ERR:-}" ]] && notify "$(msg err_config)" "$DSP_CONFIG_ERR"
    case "${1:-menu}" in
        menu|"")            show_menu ;;
        region|area)        mode_region ;;
        fullscreen|full|output) mode_fullscreen ;;
        ocr)                mode_ocr ;;
        scroll|scrolling)   mode_scroll ;;
        settings|config)    mode_settings ;;
        -h|--help|help)     usage ;;
        -v|--version)       printf '%s %s\n' "$APP_NAME" "$APP_VERSION" ;;
        --print-config)     print_config ;;
        *) usage >&2; exit 2 ;;
    esac
}

main "$@"
